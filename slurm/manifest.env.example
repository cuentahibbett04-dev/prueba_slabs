# Copy to slurm/manifest.env and edit values for your cluster.
# These values are loaded automatically by slurm/*.slurm jobs.

# Project checkout path on cluster
PROJECT_DIR=$HOME/prueba_slabs

# Data/output root on cluster scratch
DATA_DIR=$SCRATCH/prueba_slabs_data

# Python that has OpenGATE installed (used by mc/run_photon_sim.sh)
OPENGATE_PYTHON=/path/to/opengate_env/bin/python

# Optional explicit MC root override
# MC_ROOT=$DATA_DIR/mc_runs_opengate_photon_1000
